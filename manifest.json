{
  "manifest_version": 3,
  "name": "Cortex",
  "version": "1.0",
  "description": "Debloat my ass",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": ["activeTab", "storage"]
}