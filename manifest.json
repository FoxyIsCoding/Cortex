{
  "manifest_version": 3,
  "name": "Cortex",
  "version": "1.0",
  "description": "Debloats website content so you can save some of those braincells for later :3",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": ["activeTab", "storage", "tabs"]
}